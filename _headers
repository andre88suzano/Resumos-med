# Cloudflare Pages — regras de cache
#
# Obs: o HTML (/, /app) já recebe "max-age=0, must-revalidate" por padrão do
# Pages, então novos deploys aparecem ao recarregar. Aqui só damos cache longo
# aos assets estáticos para performance.

# Assets versionados do Next (nome com hash) — cache "para sempre"
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# Imagens/ícones estáticos — cache de 1 dia
/*.svg
  Cache-Control: public, max-age=86400
/*.jpg
  Cache-Control: public, max-age=86400
/*.png
  Cache-Control: public, max-age=86400
/favicon.ico
  Cache-Control: public, max-age=86400
